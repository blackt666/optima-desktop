# OPTIMA Desktop — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ─── ElevenLabs ────────────────────────────────────────────────────────────────
# Get your API key at: https://elevenlabs.io/api
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Default TTS voice ID (get from https://elevenlabs.io/voice-library)
ELEVENLABS_VOICE_ID=rachel

# STT model (scribe_multilingual for best quality, or scribe_english for English-only)
ELEVENLABS_STT_MODEL=scribe_multilingual

# ─── OpenClaw ─────────────────────────────────────────────────────────────────
# Local OpenClaw gateway URL (default: http://localhost:18789)
OPENCLAW_URL=http://localhost:18789

# OpenClaw API token (from your OpenClaw config)
OPENCLAW_API_TOKEN=your_openclaw_token_here

# ─── Whisper (optional, local fallback) ───────────────────────────────────────
# Path to whisper.cpp model (if using local Whisper instead of ElevenLabs STT)
# Download from: https://github.com/ggerganov/whisper.cpp/releases
WHISPER_MODEL_PATH=

# ─── App Settings ─────────────────────────────────────────────────────────────
# Set to 1 to enable always-listening mode on startup
ALWAYS_LISTENING=0

# Avatar position on screen: bottom-right | bottom-left | top-right | top-left
AVATAR_POSITION=bottom-right

# ─── Development ──────────────────────────────────────────────────────────────
NODE_ENV=development
